---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import { link } from '../lib/link';

const games = (await getCollection('games'))
  .filter((g) => !g.data.draft)
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return a.data.title.localeCompare(b.data.title);
  });
---
<BaseLayout title="Games — xile.us" description="Games built by Justin Poole — titles, screenshots, and source.">
  <section class="relative border-b border-[var(--border)] grid-lines">
    <div class="max-w-6xl mx-auto px-5 py-20">
      <p class="mono text-xs text-accent tracking-widest uppercase">// arcade</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight uppercase glitch">Games</h1>
      <p class="mt-4 max-w-xl text-[var(--muted)]">
        Games I've built — each with a screenshot, a short description, and a link to the code.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-12">
    {games.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {games.map((g) => <GameCard entry={g} />)}
      </div>
    ) : (
      <div class="card p-10 text-center">
        <span class="chip inline-flex" style="width:48px;height:48px"><span>◆</span></span>
        <p class="mt-4 text-[var(--muted)]">The arcade is loading — games are on their way.</p>
        <a href={link('/projects')} class="inline-block mt-4 text-xs uppercase tracking-widest text-accent">Browse projects →</a>
      </div>
    )}
  </section>
</BaseLayout>
