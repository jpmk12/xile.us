---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AppCard from '../components/AppCard.astro';
import { categories } from '../lib/categories';
import { link } from '../lib/link';

export async function getStaticPaths() {
  return categories.map((c) => ({ params: { category: c.slug }, props: { cat: c } }));
}

const { cat } = Astro.props;
const posts = (await getCollection('projects'))
  .filter((p) => !p.data.draft && p.data.category === cat.slug)
  .sort((a, b) => +b.data.date - +a.data.date);

// Flying also showcases mission-planning / aviation apps.
const apps =
  cat.slug === 'flying'
    ? (await getCollection('apps'))
        .filter((a) => !a.data.draft)
        .sort((a, b) => {
          if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
          if (a.data.order !== b.data.order) return a.data.order - b.data.order;
          return a.data.title.localeCompare(b.data.title);
        })
    : [];
---
<BaseLayout title={`${cat.label} projects — xile.us`} description={cat.blurb}>
  <section class="relative border-b border-[var(--border)] grid-lines">
    <div class="max-w-6xl mx-auto px-5 py-20">
      <p class="mono text-xs text-accent tracking-widest uppercase">// {cat.slug}</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight uppercase glitch">{cat.label}</h1>
      <p class="mt-4 max-w-xl text-[var(--muted)]">{cat.blurb}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {categories.map((c) => (
          <a href={link(`/${c.slug}`)} class={`badge mono ${c.slug === cat.slug ? 'cat-on' : 'hover:text-[var(--accent-bright)]'}`}>{c.label}</a>
        ))}
      </div>
    </div>
  </section>

  {apps.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 pt-12">
      <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// flying apps</h2>
      <p class="mt-2 text-sm text-[var(--muted)] max-w-xl">Mission-planning and aviation tools I've built.</p>
      <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {apps.map((a) => <AppCard entry={a} />)}
      </div>
    </section>
  )}

  <section class="max-w-6xl mx-auto px-5 py-12">
    {apps.length > 0 && (
      <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)] mb-6">// builds</h2>
    )}
    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((p) => <ProjectCard entry={p} />)}
      </div>
    ) : (
      <p class="text-[var(--muted)]">No {cat.label.toLowerCase()} builds posted yet — check back soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  .cat-on { color: var(--on-accent); background: var(--accent); border-color: var(--accent); }
</style>
