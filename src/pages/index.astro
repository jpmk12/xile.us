---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GameCard from '../components/GameCard.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import Subscribe from '../components/Subscribe.astro';
import { link } from '../lib/link';
import { categories } from '../lib/categories';

const all = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +b.data.date - +a.data.date);
const featured = all.find((p) => p.data.featured);
const latest = all.filter((p) => p !== featured).slice(0, 6);

const games = (await getCollection('games'))
  .filter((g) => !g.data.draft)
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return a.data.title.localeCompare(b.data.title);
  })
  .slice(0, 3);
---
<BaseLayout>
  <!-- hero -->
  <section class="relative border-b border-[var(--border)] grid-lines">
    <div class="max-w-6xl mx-auto px-5 py-24">
      <p class="mono text-xs text-accent tracking-widest uppercase">// living portfolio</p>
      <h1 class="mt-4 text-5xl sm:text-6xl font-black tracking-tight uppercase glitch">
        Build logs from<br />the makerspace
      </h1>
      <p class="mt-5 max-w-xl text-[var(--muted)]">
        Flying machines, robotics, 3D printing, and code — documented project by project,
        with photo galleries and downloadable files.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={link('/flying')}>Flying projects</Button>
        <Button href={link('/games')} variant="ghost">Games</Button>
        <Button href={link('/files')} variant="ghost">Files</Button>
      </div>
      <div class="mt-10 flex flex-wrap gap-2">
        {categories.map((c) => (
          <a href={link(`/${c.slug}`)} class="badge mono hover:text-[var(--accent-bright)] hover:border-[var(--accent-bright)] transition-colors">{c.label}</a>
        ))}
      </div>
    </div>
  </section>

  {featured && (
    <section class="max-w-6xl mx-auto px-5 pt-16">
      <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// featured build</h2>
      <a href={link(`/projects/${featured.id}`)} class="card group mt-6 grid md:grid-cols-2 overflow-hidden">
        <div class="aspect-[16/10] md:aspect-auto grid-lines border-b md:border-b-0 md:border-r border-[var(--border)] relative flex items-center justify-center overflow-hidden">
          <span class="chip absolute" style="width:48px;height:48px"><span>◆</span></span>
          {featured.data.cover && (
            <img src={link(featured.data.cover)} alt="" loading="lazy" onerror="this.remove()" class="relative w-full h-full object-cover" />
          )}
        </div>
        <div class="p-7 flex flex-col justify-center">
          <div class="mono text-xs text-[var(--muted)] flex items-center gap-2">
            <span>{featured.data.date.toISOString().slice(0, 10)}</span><span>·</span><span>{featured.data.category}</span>
            <Badge status={featured.data.status} />
          </div>
          <h3 class="mt-2 text-2xl font-black tracking-tight uppercase glitch group-hover:text-[var(--accent-bright)] transition-colors">{featured.data.title}</h3>
          <p class="mt-3 text-[var(--muted)]">{featured.data.summary}</p>
          <span class="mt-4 text-xs uppercase tracking-widest text-accent">Read the build →</span>
        </div>
      </a>
    </section>
  )}

  <!-- latest builds -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// latest builds</h2>
      <a href={link('/projects')} class="text-xs uppercase tracking-widest text-accent">All →</a>
    </div>
    <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {latest.map((p) => <ProjectCard entry={p} />)}
    </div>
  </section>

  {games.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 pb-16">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// games</h2>
        <a href={link('/games')} class="text-xs uppercase tracking-widest text-accent">All →</a>
      </div>
      <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {games.map((g) => <GameCard entry={g} />)}
      </div>
    </section>
  )}

  <Subscribe />
</BaseLayout>
