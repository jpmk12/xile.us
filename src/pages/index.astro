---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Button from '../components/Button.astro';
import { projects } from '../data/projects';
import { link } from '../lib/link';

const latest = projects.slice(0, 6);
const categories = ['code', 'robotics', '3d-printing', 'halloween'];
---
<BaseLayout>
  <!-- hero -->
  <section class="relative border-b border-[var(--border)] grid-lines">
    <div class="max-w-6xl mx-auto px-5 py-24">
      <p class="mono text-xs text-accent tracking-widest uppercase">// living portfolio</p>
      <h1 class="mt-4 text-5xl sm:text-6xl font-black tracking-tight uppercase glitch">
        Build logs from<br />the makerspace
      </h1>
      <p class="mt-5 max-w-xl text-[var(--muted)]">
        Code, robotics, 3D printing, and Halloween engineering — documented project by
        project, with photo galleries and downloadable files.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={link('/projects')}>Browse projects</Button>
        <Button href={link('/files')} variant="ghost">Download files</Button>
      </div>
      <div class="mt-10 flex flex-wrap gap-2">
        {categories.map((c) => <span class="badge mono">{c}</span>)}
      </div>
    </div>
  </section>

  <!-- latest builds -->
  <section class="max-w-6xl mx-auto px-5 py-16">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// latest builds</h2>
      <a href={link('/projects')} class="text-xs uppercase tracking-widest text-accent">All →</a>
    </div>
    <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {latest.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</BaseLayout>
