---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — xile.us">
  <section class="max-w-3xl mx-auto px-5 py-16">
    <p class="mono text-xs text-accent tracking-widest uppercase">// operator</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight uppercase">About</h1>
    <div class="mt-5 space-y-4 text-[var(--muted)] leading-relaxed">
      <p>
        xile.us is the workshop notebook of Justin Poole — a running log of makerspace
        projects spanning code, robotics, 3D printing, and Halloween engineering.
      </p>
      <p>
        It's part of the <span class="text-accent">DEAD</span> family of sites, and shares
        their look: a dark ops-terminal palette with a swappable accent. Real write-ups,
        photos, and files for every build will fill in through Phases 2–3.
      </p>
    </div>
  </section>
</BaseLayout>
