---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';

const sorted = [...projects].sort((a, b) => (a.date < b.date ? 1 : -1));
const tags = Array.from(new Set(projects.flatMap((p) => p.tags))).sort();
---
<BaseLayout title="Projects — xile.us">
  <section class="max-w-6xl mx-auto px-5 py-16">
    <p class="mono text-xs text-accent tracking-widest uppercase">// archive</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight uppercase">Projects</h1>
    <p class="mt-3 max-w-xl text-[var(--muted)]">
      Every build, newest first. Tag filtering becomes interactive in Phase 3.
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {tags.map((t) => <span class="badge mono">{t}</span>)}
    </div>

    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</BaseLayout>
