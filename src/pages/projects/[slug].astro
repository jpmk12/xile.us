---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Lightbox from '../../components/Lightbox.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SpecCard from '../../components/SpecCard.astro';
import Bom from '../../components/Bom.astro';
import Model3D from '../../components/Model3D.astro';
import SeriesNav from '../../components/SeriesNav.astro';
import UpdateLog from '../../components/UpdateLog.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import Comments from '../../components/Comments.astro';
import { link } from '../../lib/link';
import { fileMeta } from '../../lib/files';
import { getCategory } from '../../lib/categories';

export async function getStaticPaths() {
  const posts = await getCollection('projects');
  return posts.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, tags, status, cover, summary, downloads, category, specs, bom, models, series, updates } = entry.data;
const d = date.toISOString().slice(0, 10);
const cat = getCategory(category);

let seriesParts: { id: string; title: string }[] = [];
if (series) {
  seriesParts = (await getCollection('projects'))
    .filter((p) => !p.data.draft && p.data.series === series)
    .sort((a, b) => +a.data.date - +b.data.date)
    .map((p) => ({ id: p.id, title: p.data.title }));
}

const related = (await getCollection('projects'))
  .filter((p) => !p.data.draft && p.data.category === category && p.id !== entry.id)
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 3);

const ogImageAbs = new URL(link(cover ?? '/og-default.png'), Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  datePublished: date.toISOString(),
  description: summary,
  image: ogImageAbs,
  author: { '@type': 'Person', name: 'Justin Poole' },
  keywords: tags.join(', '),
  articleSection: cat?.label,
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
---
<BaseLayout title={`${title} — xile.us`} description={summary} ogImage={cover ?? '/og-default.png'}>
  <article class="max-w-3xl mx-auto px-5 py-16" data-pagefind-body>
    <a href={link('/projects')} class="mono text-xs text-accent">← all projects</a>

    <div class="mt-5 mono text-xs text-[var(--muted)] flex items-center gap-3">
      <span>{d}</span><Badge status={status} />
    </div>
    <h1 class="mt-3 text-4xl font-black tracking-tight uppercase">{title}</h1>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      {cat && (
        <a href={link(`/${cat.slug}`)} class="badge mono cat-pill">{cat.label}</a>
      )}
      {tags.map((t) => (
        <a href={link(`/tags/${t}`)} class="badge mono hover:text-[var(--accent-bright)] hover:border-[var(--accent-bright)] transition-colors">#{t}</a>
      ))}
    </div>

    {series && seriesParts.length > 1 && (
      <SeriesNav series={series} parts={seriesParts} currentId={entry.id} />
    )}

    {cover && (
      <img src={link(cover)} alt="" onerror="this.remove()"
           class="mt-8 w-full rounded-lg border border-[var(--border)]" />
    )}

    {specs.length > 0 && <SpecCard specs={specs} />}

    <div class="post mt-8">
      <Content />
    </div>

    {updates.length > 0 && <UpdateLog updates={updates} />}
    {bom.length > 0 && <Bom bom={bom} />}
    {models.length > 0 && <Model3D models={models} />}

    {downloads.length > 0 && (
      <section class="mt-12">
        <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// files</h2>
        <div class="mt-4 card divide-y divide-[var(--border)]">
          {downloads.map((dl) => {
            const { ext, size } = fileMeta(dl.file);
            return (
              <a href={link(dl.file)} download class="flex items-center justify-between gap-4 p-4 hover:bg-[var(--panel-soft)] transition-colors">
                <div class="flex items-center gap-3 min-w-0">
                  <span class="chip" style="width:34px;height:34px"><span class="text-xs">◆</span></span>
                  <span class="truncate">{dl.label}</span>
                </div>
                <div class="flex items-center gap-3 mono text-xs text-[var(--muted)] flex-none">
                  <span>{ext}</span>{size && <span>{size}</span>}
                  <span class="badge">Download</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="mt-14">
        <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">
          // more in {cat?.label ?? category}
        </h2>
        <div class="mt-5 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {related.map((p) => <ProjectCard entry={p} />)}
        </div>
      </section>
    )}

    <ShareButtons title={title} />
    <Comments />
  </article>
  <Lightbox />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>

<style>
  .cat-pill { color: var(--on-accent); background: var(--accent); border-color: var(--accent); }
</style>
