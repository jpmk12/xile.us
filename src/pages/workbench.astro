---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { link } from '../lib/link';

const all = (await getCollection('projects')).filter((p) => !p.data.draft);
const inProgress = all
  .filter((p) => p.data.status === 'in-progress')
  .sort((a, b) => +b.data.date - +a.data.date);
const recent = all.sort((a, b) => +b.data.date - +a.data.date).slice(0, 3);
---
<BaseLayout title="Workbench — xile.us" description="What's on the bench right now — projects currently in progress.">
  <section class="relative border-b border-[var(--border)] grid-lines">
    <div class="max-w-6xl mx-auto px-5 py-20">
      <p class="mono text-xs text-accent tracking-widest uppercase">// now</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight uppercase glitch">Workbench</h1>
      <p class="mt-4 max-w-xl text-[var(--muted)]">What's actively being built right now.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-12">
    {inProgress.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {inProgress.map((p) => <ProjectCard entry={p} />)}
      </div>
    ) : (
      <div class="card p-8 text-center">
        <p class="text-[var(--muted)]">Nothing on the bench at the moment — everything's flying. 🛠️</p>
        <a href={link('/projects')} class="inline-block mt-4 text-xs uppercase tracking-widest text-accent">Browse all builds →</a>
      </div>
    )}

    <h2 class="mt-16 text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// latest builds</h2>
    <div class="mt-5 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {recent.map((p) => <ProjectCard entry={p} />)}
    </div>
  </section>
</BaseLayout>
