---
const themes = ['nightwatch', 'amber', 'arctic', 'mission'];
---
<div class="flex items-center gap-1.5" role="group" aria-label="Color theme">
  {themes.map((t) => (
    <button
      type="button"
      data-theme-btn={t}
      data-t={t}
      title={`Theme: ${t}`}
      aria-label={`Switch theme to ${t}`}
      class="swatch w-4 h-4 rounded-full border border-[var(--border)] transition-transform hover:scale-110"
    ></button>
  ))}
</div>

<style>
  .swatch[data-t="nightwatch"] { background: #34d399; }
  .swatch[data-t="amber"]      { background: #fbbf24; }
  .swatch[data-t="arctic"]     { background: #38bdf8; }
  .swatch[data-t="mission"]    { background: #f5f4f0; } /* light theme */
</style>

<script is:inline>
  (function () {
    var KEY = 'xile-theme';
    var root = document.documentElement;
    function paint() {
      var cur = root.getAttribute('data-theme') || 'nightwatch';
      document.querySelectorAll('[data-theme-btn]').forEach(function (b) {
        var on = b.getAttribute('data-theme-btn') === cur;
        b.style.outline = on ? '2px solid var(--accent-bright)' : 'none';
        b.style.outlineOffset = '2px';
      });
    }
    function set(t) {
      root.setAttribute('data-theme', t);
      try { localStorage.setItem(KEY, t); } catch (e) {}
      var bg = getComputedStyle(root).getPropertyValue('--bg').trim();
      var m = document.querySelector('meta[name="theme-color"]');
      if (m && bg) m.setAttribute('content', bg);
      paint();
    }
    document.querySelectorAll('[data-theme-btn]').forEach(function (b) {
      b.addEventListener('click', function () { set(b.getAttribute('data-theme-btn')); });
    });
    paint();
  })();
</script>
