---
interface Props { href?: string; variant?: 'solid' | 'ghost'; }
const { href, variant = 'solid' } = Astro.props;
const cls = `btn ${variant === 'solid' ? 'btn-solid' : 'btn-ghost'}`;
---
{href ? (
  <a class={cls} href={href}><slot /></a>
) : (
  <button type="button" class={cls}><slot /></button>
)}
