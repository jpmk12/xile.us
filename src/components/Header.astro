---
import Mark from './Mark.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';
import { link } from '../lib/link';

const nav = [
  { href: link('/flying'), label: 'Flying' },
  { href: link('/games'), label: 'Games' },
  { href: link('/projects'), label: 'Projects' },
  { href: link('/files'), label: 'Files' },
  { href: link('/search'), label: 'Search' },
  { href: link('/about'), label: 'About' },
];
---
<header class="header-bg sticky top-0 z-40 border-b border-[var(--border)]">
  <div class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between gap-4">
    <Mark />
    <nav class="hidden sm:flex items-center gap-6 text-xs font-bold uppercase tracking-widest text-[var(--muted)]">
      {nav.map((n) => (
        <a href={n.href} class="hover:text-[var(--accent-bright)] transition-colors">{n.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <ThemeSwitcher />
      <button
        id="nav-toggle"
        type="button"
        class="sm:hidden text-[var(--muted)] hover:text-[var(--accent-bright)] transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="nav-mobile" class="sm:hidden hidden border-t border-[var(--border)]">
    <div class="max-w-6xl mx-auto px-5 py-1 flex flex-col text-xs font-bold uppercase tracking-widest">
      {nav.map((n) => (
        <a href={n.href} class="py-3 border-b border-[var(--border-soft)] last:border-0 text-[var(--muted)] hover:text-[var(--accent-bright)] transition-colors">{n.label}</a>
      ))}
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('nav-toggle');
    var menu = document.getElementById('nav-mobile');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      var hidden = menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', hidden ? 'false' : 'true');
    });
  })();
</script>
