---
// Click any image inside .post or .gallery to open a fullscreen lightbox with
// keyboard + prev/next navigation. Reduced-motion safe; pure CSS/JS, no deps.
---
<div id="lb" class="lb" aria-hidden="true" role="dialog" aria-label="Image viewer">
  <button class="lb-btn lb-x" aria-label="Close">✕</button>
  <button class="lb-btn lb-prev" aria-label="Previous image">‹</button>
  <img class="lb-img" alt="" />
  <button class="lb-btn lb-next" aria-label="Next image">›</button>
  <div class="lb-count mono"></div>
</div>

<style>
  .lb { position: fixed; inset: 0; z-index: 80; display: none; align-items: center; justify-content: center;
        background: color-mix(in srgb, var(--bg) 92%, black); backdrop-filter: blur(4px); }
  .lb.open { display: flex; }
  .lb-img { max-width: 92vw; max-height: 86vh; border: 1px solid var(--border); border-radius: .5rem; }
  .lb-btn { position: absolute; background: transparent; border: 0; color: var(--text); cursor: pointer; line-height: 1; }
  .lb-x { top: 1rem; right: 1.25rem; font-size: 1.4rem; }
  .lb-prev, .lb-next { top: 50%; transform: translateY(-50%); font-size: 2.75rem; padding: 0 1rem; color: var(--muted); }
  .lb-prev { left: .25rem; } .lb-next { right: .25rem; }
  .lb-btn:hover { color: var(--accent-bright); }
  .lb-count { position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%); color: var(--muted); font-size: .75rem; }
  :global(.post img), :global(.gallery img) { cursor: zoom-in; }
</style>

<script is:inline>
  (function () {
    var lb = document.getElementById('lb');
    if (!lb) return;
    var img = lb.querySelector('.lb-img');
    var count = lb.querySelector('.lb-count');
    var prev = lb.querySelector('.lb-prev');
    var next = lb.querySelector('.lb-next');
    var items = [], idx = 0;

    function fullSrc(el) {
      var a = el.closest('a');
      var href = a && a.getAttribute('href');
      if (href && /\.(jpe?g|png|gif|webp|avif)(\?|$)/i.test(href)) return href;
      return el.getAttribute('src');
    }
    function collect() {
      items = [].slice.call(document.querySelectorAll('.post img, .gallery img'))
        .filter(function (im) { return im.getAttribute('src'); });
    }
    function show(i) {
      if (!items.length) return;
      idx = (i + items.length) % items.length;
      img.src = fullSrc(items[idx]);
      count.textContent = (idx + 1) + ' / ' + items.length;
      var multi = items.length > 1 ? 'block' : 'none';
      count.style.display = multi; prev.style.display = multi; next.style.display = multi;
    }
    function open(i) { lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false'); show(i); }
    function close() { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); img.src = ''; }

    // stop wrapping <a> from navigating when its image is clicked
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('.post a, .gallery a');
      if (a && a.querySelector('img') && /\.(jpe?g|png|gif|webp|avif)(\?|$)/i.test(a.getAttribute('href') || '')) {
        e.preventDefault();
      }
    }, true);
    // open lightbox on image click
    document.addEventListener('click', function (e) {
      var im = e.target.closest && e.target.closest('.post img, .gallery img');
      if (im) { e.preventDefault(); collect(); open(items.indexOf(im)); }
    });

    lb.querySelector('.lb-x').addEventListener('click', close);
    prev.addEventListener('click', function (e) { e.stopPropagation(); show(idx - 1); });
    next.addEventListener('click', function (e) { e.stopPropagation(); show(idx + 1); });
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
    document.addEventListener('keydown', function (e) {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  })();
</script>
