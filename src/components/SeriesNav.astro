---
import { link } from '../lib/link';
import { prettify } from '../lib/site';
interface Props {
  series: string;
  parts: { id: string; title: string }[];
  currentId: string;
}
const { series, parts, currentId } = Astro.props;
const idx = parts.findIndex((p) => p.id === currentId);
const prev = parts[idx - 1];
const next = parts[idx + 1];
---
<div class="card p-5 mt-6">
  <div class="flex items-center justify-between gap-3">
    <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// build log: {prettify(series)}</h2>
    <a href={link(`/series/${series}`)} class="mono text-xs text-accent flex-none">all parts →</a>
  </div>
  <ol class="mt-3 space-y-1.5">
    {parts.map((p, i) => (
      <li class="flex items-center gap-3 text-sm">
        <span class="mono text-xs text-[var(--muted)]">{String(i + 1).padStart(2, '0')}</span>
        {p.id === currentId ? (
          <span class="font-semibold text-accent">{p.title}</span>
        ) : (
          <a href={link(`/projects/${p.id}`)} class="hover:text-[var(--accent-bright)] transition-colors">{p.title}</a>
        )}
      </li>
    ))}
  </ol>
  {(prev || next) && (
    <div class="mt-4 pt-3 border-t border-[var(--border)] flex justify-between gap-3 mono text-xs">
      {prev ? <a href={link(`/projects/${prev.id}`)} class="text-accent hover:text-[var(--accent-bright)]">← {prev.title}</a> : <span></span>}
      {next ? <a href={link(`/projects/${next.id}`)} class="text-accent hover:text-[var(--accent-bright)] text-right">{next.title} →</a> : <span></span>}
    </div>
  )}
</div>
