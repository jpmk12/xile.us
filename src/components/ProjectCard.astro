---
import Badge from './Badge.astro';
import { link } from '../lib/link';
import type { CollectionEntry } from 'astro:content';

interface Props { entry: CollectionEntry<'projects'>; }
const { entry } = Astro.props;
const { title, date, tags, status, summary, cover } = entry.data;
const d = date.toISOString().slice(0, 10);
---
<a href={link(`/projects/${entry.id}`)} class="card group block overflow-hidden">
  <div class="aspect-[16/10] grid-lines border-b border-[var(--border)] relative flex items-center justify-center overflow-hidden">
    <span class="chip absolute" style="width:44px;height:44px"><span>◆</span></span>
    {cover && (
      <img src={link(cover)} alt="" loading="lazy" onerror="this.remove()"
           class="relative w-full h-full object-cover" />
    )}
    <span class="absolute top-3 right-3 z-10"><Badge status={status} /></span>
  </div>
  <div class="p-5">
    <div class="mono text-xs text-[var(--muted)] flex items-center gap-2">
      <span>{d}</span><span>·</span><span class="truncate">{tags.slice(0, 3).join(' / ')}</span>
    </div>
    <h3 class="mt-2 text-lg font-bold tracking-wide uppercase glitch group-hover:text-[var(--accent-bright)] transition-colors">
      {title}
    </h3>
    <p class="mt-2 text-sm text-[var(--muted)] line-clamp-2">{summary}</p>
  </div>
</a>
