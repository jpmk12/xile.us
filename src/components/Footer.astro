---
import { link } from '../lib/link';
---
<footer class="border-t border-[var(--border)] mt-16">
  <div class="max-w-6xl mx-auto px-5 py-10 flex flex-col sm:flex-row gap-3 items-center justify-between text-xs text-[var(--muted)]">
    <p class="mono">xile.us — © 2026 Justin Poole</p>
    <div class="flex items-center gap-4 mono uppercase tracking-widest">
      <a href={link('/rss.xml')} class="hover:text-[var(--accent-bright)]">RSS</a>
      <span>part of the DEAD family</span>
    </div>
  </div>
</footer>
