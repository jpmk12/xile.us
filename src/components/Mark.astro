---
import { link } from '../lib/link';
interface Props { size?: number; withText?: boolean; }
const { size = 36, withText = true } = Astro.props;
---
<a href={link('/')} class="flex items-center gap-3 group" aria-label="xile.us home">
  <span class="chip" style={`width:${size}px;height:${size}px`}>
    <span class="text-sm">◆</span>
  </span>
  {withText && (
    <span class="text-base font-bold tracking-widest uppercase glitch">xile<span class="text-accent">.us</span></span>
  )}
</a>
