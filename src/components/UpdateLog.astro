---
interface Props { updates: { date: string; note: string }[]; }
const { updates } = Astro.props;
const sorted = [...updates].sort((a, b) => (a.date < b.date ? 1 : -1));
---
<section class="mt-12">
  <h2 class="text-sm font-bold uppercase tracking-widest text-[var(--muted)]">// update log</h2>
  <ol class="mt-4 relative border-l border-[var(--border)] pl-5 space-y-5">
    {sorted.map((u) => (
      <li class="relative">
        <span class="absolute -left-[1.45rem] top-1.5 w-2 h-2 rounded-full bg-[var(--accent)]"></span>
        <div class="mono text-xs text-[var(--muted)]">{u.date}</div>
        <p class="mt-1 text-sm leading-relaxed">{u.note}</p>
      </li>
    ))}
  </ol>
</section>
